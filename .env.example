COMPOSE_PROJECT_NAME=digital-cip

POSTGRES_USER=cip
POSTGRES_PASSWORD=cip
POSTGRES_DB=cip_development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_VHOST=/

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_BUCKET=documents
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1

RAILS_ENV=development
RAILS_MASTER_KEY=
SECRET_KEY_BASE=replace_me_with_64_random_chars_minimum_for_real_deployment

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
CHUNK_SIZE=800
CHUNK_OVERLAP=120

OCR_LANG=eng
OCR_DPI=200

MAX_RETRIES=5
RETRY_TTL_MS=5000

LOG_LEVEL=info

API_HTTP_PORT=3040
GRAFANA_HTTP_PORT=3010
