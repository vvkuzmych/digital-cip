{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "title": "Ingestion pipeline",
  "uid": "ingestion",
  "tags": ["digital-cip"],
  "schemaVersion": 39,
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Messages processed (5m rate)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum by (service) (rate(worker_messages_processed_total[5m]))", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Failures (5m rate)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum by (service) (rate(worker_messages_failed_total[5m]))", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "p95 processing time (s) per stage",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, service) (rate(worker_processing_seconds_bucket[5m])))", "legendFormat": "{{service}}" }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "Queue depth (RabbitMQ)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "rabbitmq_queue_messages_ready{queue=~\"ingest.*\"}", "legendFormat": "{{queue}}" }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "title": "In-flight per worker",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "worker_in_flight", "legendFormat": "{{service}}" }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 }
    }
  ]
}
